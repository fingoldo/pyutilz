# Copy this file to ``.env`` and fill in your provider API keys.
# ``.env`` is gitignored; ``.env.example`` is the committed template.
#
# Each key is OPTIONAL. Tests marked ``@pytest.mark.live`` for a given
# provider are skipped when its key is absent (see tests/conftest.py).
# Run live tests with: ``pytest -m live``
# Skip them by default: ``pytest -m "not live"`` (the default in CI).

# ── OpenRouter ────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
# Recommended: set a credit cap on the key in the OR dashboard.
OPENROUTER_API_KEY=

# ── Anthropic Claude ──────────────────────────────────────────────
# Get a key at https://console.anthropic.com/settings/keys
# Recommended: set a workspace-level monthly budget alert.
ANTHROPIC_API_KEY=

# ── OpenAI ─────────────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
# Recommended: use a project-restricted key with a hard usage cap.
OPENAI_API_KEY=

# ── DeepSeek ───────────────────────────────────────────────────────
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── xAI Grok ───────────────────────────────────────────────────────
# Get a key at https://console.x.ai (starts with ``xai-``).
XAI_API_KEY=

# ── Google Gemini ──────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
